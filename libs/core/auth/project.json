{
  "name": "auth",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/features/auth/src",
  "prefix": "app",
  "tags": ["feature:auth", "type:feature"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{options.outputPath}"],
      "options": {
        "tsConfig": "libs/features/auth/tsconfig.lib.json",
        "project": "libs/features/auth/ng-package.json"
      },
      "dependsOn": ["firebase:build"],
      "configurations": {
        "production": {
          "tsConfig": "libs/features/auth/tsconfig.lib.prod.json"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/features/auth/**/*.ts", "libs/features/auth/**/*.html"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/features/auth/jest.config.cts",
        "tsConfig": "libs/features/auth/tsconfig.spec.json"
      }
    }
  }
}
